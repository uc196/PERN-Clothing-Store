{
  "compilerOptions": {
    // Environment Settings
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "ES2020",
    "types": ["node"],

    // File Layout
    "rootDir": "./",
    "outDir": "./dist",

    // Strict Type Checking
    "strict": true,

    // Compatibility & Safety
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist"]
}